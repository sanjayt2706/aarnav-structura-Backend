# ---- Server ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ---- JWT ----
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change_this_too_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# ---- Local MySQL (primary, source of truth) ----
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=your_local_password
LOCAL_DB_NAME=aarnav_structura

# ---- Cloud MySQL (backup / production mirror) ----
# Every enquiry write is mirrored here. If this is down, local writes still succeed.
CLOUD_DB_ENABLED=true
CLOUD_DB_HOST=your-cloud-host.mysql.database.azure.com
CLOUD_DB_PORT=3306
CLOUD_DB_USER=cloud_user
CLOUD_DB_PASSWORD=your_cloud_password
CLOUD_DB_NAME=aarnav_structura
CLOUD_DB_SSL=true

# ---- Email (Nodemailer via SMTP, e.g. Gmail App Password or SendGrid SMTP) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
MAIL_FROM="Aarnav Structura <no-reply@aarnavstructura.com>"
COMPANY_NOTIFY_EMAIL=satvikrajgowda282@gmail.com

# ---- Uploads ----
MAX_UPLOAD_MB=8

# ---- Seed admin (used once by migrations/seed.js) ----
SEED_ADMIN_EMAIL=admin@aarnavstructura.com
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Super Admin
